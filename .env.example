# ── AI provider ───────────────────────────────────────────────────────────────
# AI_PROVIDER selects which API to use. Default: anthropic
# Options: anthropic | openai
# "openai" works with any OpenAI-compatible provider — set AI_BASE_URL to switch.
AI_PROVIDER=anthropic

# Master key — overrides provider-specific keys below
AI_API_KEY=

# Provider-specific keys (used when AI_API_KEY is not set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: override the API base URL for OpenAI-compatible providers
# Fireworks:  https://api.fireworks.ai/inference/v1
# Together:   https://api.together.xyz/v1
# OpenRouter: https://openrouter.ai/api/v1
# Local LLM:  http://localhost:11434/v1
AI_BASE_URL=

# Optional: override the model for all pipeline stages
# Anthropic examples: claude-opus-4-8, claude-sonnet-4-6
# OpenAI examples:    gpt-4o, gpt-4o-mini
# Fireworks example:  accounts/fireworks/models/llama-v3p3-70b-instruct
AI_MODEL=

# ── Source: NocoDB ────────────────────────────────────────────────────────────
# Set these when source.type = "nocodb" in your config
NOCODB_BASE_URL=
NOCODB_API_TOKEN=
NOCODB_TABLE_ID=

# ── Source: local files ───────────────────────────────────────────────────────
# Set these when source.type = "csv" or "json" in your config
INPUT_CSV_PATH=inputs/articles.csv
INPUT_JSON_PATH=inputs/articles.json

# ── Source: Google Sheets ─────────────────────────────────────────────────────
# Absolute path to your service account credentials JSON file
# Share the spreadsheet with the service account email address
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Sheet1

# ── Publisher: Markdown export ────────────────────────────────────────────────
# Absolute or relative path where exported .md files are written
EXPORT_MARKDOWN_DIR=outputs/markdown

# ── Publisher: GitHub (optional) ─────────────────────────────────────────────
# Only required when output.github.enabled = true in your config
# Create a fine-grained token at https://github.com/settings/tokens
# with Contents: Read and Write permission on the target repository
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_FOLDER=content/articles

# ── Publisher: Framer CMS (optional) ─────────────────────────────────────────
# Only required when output.framer.enabled = true in your config
FRAMER_TOKEN=
FRAMER_COLLECTION_ID=

# ── UI server ──────────────────────────────────────────────────
# Optional: protect the web UI with a token when self-hosting.
# If set, the UI will require this token on login.
# Leave blank for local development (no auth required).
PIPELINE_AUTH_TOKEN=
UI_PORT=3737
